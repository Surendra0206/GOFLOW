{
  "env": {
    "browser": true,
    "es6": true,
    "node": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-console": "off",
    "semi": ["warn", "always"],
    "quotes": ["off"],
    "indent": ["warn", 2, { "SwitchCase": 1 }],
    "no-trailing-spaces": "warn",
    "comma-dangle": ["warn", "only-multiline"],
    "no-var": "off",
    "prefer-const": "off",
    "camelcase": "off"
  },
  "globals": {
    "localStorage": "readonly",
    "confirm": "readonly",
    "console": "readonly",
    "document": "readonly",
    "setTimeout": "readonly",
    "clearTimeout": "readonly",
    "fetch": "readonly",
    "ApiService": "readonly",
    "GOFLOW_CONFIG": "readonly"
  },
  "ignorePatterns": ["node_modules/", "dist/", "config.js"]
}
